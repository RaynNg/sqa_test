              { "key": "Authorization", "value": "Bearer {{studentToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"period_id\": {{periodId}},\n  \"preferences\": [\n    { \"enterprise_id\": 1, \"preference_order\": 1 }\n  ]\n}",
