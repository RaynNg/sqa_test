            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"period_id\": {{periodId}},\n  \"preferences\": [\n    { \"enterprise_id\": 1, \"preference_order\": 1 },\n    { \"enterprise_id\": 2, \"preference_order\": 3 }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/internship-registrations/preferences" }
          }
        },
        {
          "name": "TC-REG-STU-06 POST Register Preferences - Valid (CSV: 1/3/5 enterprises)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var raw = pm.iterationData.get('enterprise_ids') || pm.environment.get('enterpriseId') || '1';",
                  "var ids = raw.toString().split('|');",
                  "var prefs = ids.map(function(id, idx) {",
                  "  return { enterprise_id: parseInt(id.trim()), preference_order: idx + 1 };",
                  "});",
                  "pm.collectionVariables.set('preferencesJson', JSON.stringify(prefs));",
                  "console.log('[CSV] Building', ids.length, 'enterprise preferences:', JSON.stringify(prefs));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var expectedCount = (pm.iterationData.get('enterprise_ids') || '1').toString().split('|').length;",
                  "pm.test('TC-REG-STU-06: Status 200 or 201', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('TC-REG-STU-06: Registered ' + expectedCount + ' preference(s)', function () {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json).to.exist;",
                  "  if (json.id) pm.collectionVariables.set('regPrefId', json.id);",
                  "  else if (Array.isArray(json) && json.length > 0) pm.collectionVariables.set('regPrefId', json[0].id);",
                  "  else if (json.ids && json.ids.length > 0) pm.collectionVariables.set('regPrefId', json.ids[0]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{studentToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"period_id\": {{periodId}},\n  \"preferences\": {{preferencesJson}}\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/internship-registrations/preferences" }
          }
        },
