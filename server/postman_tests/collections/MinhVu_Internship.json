    {
      "name": "03. Registration - Student",
      "description": "Negative cases run BEFORE positive to test guard rules. Order: no-lecturer-guard → register-lecturer → preference-validation → register-preferences.",
      "item": [
        {
          "name": "TC-REG-STU-01 POST Preferences Without Lecturer First → 400",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('TC-REG-STU-01: Status 400 - must register lecturer first', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "pm.test('TC-REG-STU-01: Error message about lecturer requirement', function () {",
                  "  var body = pm.response.text();",
                  "  pm.expect(body).to.not.be.empty;",
                  "});"
